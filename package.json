{
  "name": "mi-api-wrapper",
  "version": "1.0.0",
  "description": "Un wrapper híbrido (ESM/CJS) para obtener imágenes aleatorias de animales.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npx esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "animals",
    "images",
    "wrapper",
    "esm",
    "cjs"
  ],
  "author": "darkcore",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "dependencies": {
    "axios": "^1.13.5"
  }
}
